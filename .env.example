# Copy this file to server/.env and fill in real values as they become available.
# Everything below has a safe fallback for local testing (see comments).

PORT=4000

# CORS/cookie origin isn't needed in dev (Vite proxies /api), left here for reference only.

# --- Admin notification address -----------------------------------------
# TEMPORARY testing value. Swap later by changing this env var only — no code change needed.
ADMIN_EMAIL=alexabrahametc@gmail.com

# --- SMTP (real email sending) -------------------------------------------
# NOT READY YET. Until all four of these are set, the server falls back to
# logging verification codes / email bodies to the console so the flow is
# still fully testable end-to-end without real email.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Payment QR ------------------------------------------------------------
# Path (relative to server/) to the static UPI/GPay QR code image shown to
# students in Step 4. Placeholder until the real QR image is supplied.
PAYMENT_QR_IMAGE=uploads/payment-qr.png

# --- Session secret ----------------------------------------------------------
SESSION_SECRET=dev-secret-change-me
